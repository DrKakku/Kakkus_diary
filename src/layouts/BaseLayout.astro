---
import "../styles/global.css";
import { siteConfig } from "../config/site.config";
import { withBase } from "../lib/content";

const {
  title = siteConfig.siteName,
  description = siteConfig.siteDescription,
  theme = "portfolio",
  enableWritingEnhancers = false,
} = Astro.props as {
  title?: string;
  description?: string;
  theme?: "portfolio" | "writing";
  enableWritingEnhancers?: boolean;
};

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function navHref(href: string, kind: "internal" | "external" = "internal") {
  return kind === "internal" ? withBase(href) : href;
}

function isActive(href: string) {
  if (href === "/") {
    return currentPath === (withBase("/").replace(/\/$/, "") || "/");
  }

  if (href === "/writing" && theme === "writing") {
    return true;
  }

  const target = withBase(href).replace(/\/$/, "") || "/";
  return currentPath === target || currentPath.startsWith(`${target}/`);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={["site-body", `theme-${theme}`]}>
    <div class="site-noise"></div>
    <div class="site-frame">
      <header class="site-header">
        <a class="brand-lockup" href={withBase("/")}>
          <span class="brand-mark">YT</span>
          <span>
            <strong>{siteConfig.siteName}</strong>
            <small>{siteConfig.profile.title}</small>
          </span>
        </a>

        <nav class="primary-nav" aria-label="Primary">
          {siteConfig.navigation.map((item) => (
            <a class:list={["nav-link", isActive(item.href) && "active"]} href={withBase(item.href)}>
              {item.label}
            </a>
          ))}
        </nav>
      </header>

      <main class="page-shell">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-hero">
          <p class="eyebrow">Built From Notes</p>
          <h2>{siteConfig.profile.name}</h2>
          <p class="footer-copy">{siteConfig.footer.manifesto}</p>
          <p class="footer-caption">{siteConfig.footer.caption}</p>
        </div>

        <div class="footer-column">
          <p class="footer-label">Navigate</p>
          <div class="footer-links">
            {siteConfig.quickLinks.map((link) => (
              <a href={navHref(link.href, link.kind as "internal" | "external")}>
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <div class="footer-column">
          <p class="footer-label">Connect</p>
          <div class="footer-links">
            {siteConfig.socialLinks.map((link) => (
              <a href={navHref(link.href, link.kind as "internal" | "external")} target={link.kind === "external" ? "_blank" : undefined} rel={link.kind === "external" ? "noreferrer" : undefined}>
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </footer>
    </div>

    {enableWritingEnhancers && <script>
      import "../scripts/writing-enhancers";
    </script>}
  </body>
</html>
