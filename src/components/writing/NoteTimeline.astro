---
import { formatDate, withBase } from "../../lib/content";
import type { NoteRecord } from "../../lib/site-data";

const { notes } = Astro.props as { notes: NoteRecord[] };
---

<ol class="timeline-shell relative space-y-6 pl-8">
  {notes.map((note) => (
    <li class="relative">
      <span class="absolute -left-[1.9rem] top-2 h-3.5 w-3.5 rounded-full border-2 border-base-100 bg-primary shadow"></span>
      <article class="card border border-base-300 bg-base-100/85 shadow-sm">
        <div class="card-body gap-3 p-5">
          <div class="flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.18em] text-base-content/50">
            <span>{formatDate(note.canonicalDate)}</span>
            <span>•</span>
            <span>{note.sectionLabel}</span>
          </div>
          <div class="space-y-2">
            <h3 class="text-lg font-semibold"><a class="link link-hover" href={note.url}>{note.title}</a></h3>
            <p class="text-sm leading-7 text-base-content/70">{note.summary}</p>
          </div>
          {note.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {note.tags.slice(0, 4).map((tag) => (
                <a class="badge badge-outline" href={withBase(`/writing/tags/${tag.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`)}>
                  {tag}
                </a>
              ))}
            </div>
          )}
        </div>
      </article>
    </li>
  ))}
</ol>
