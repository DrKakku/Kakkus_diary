---
const { items } = Astro.props as {
  items: {
    notes: Array<{
      title: string;
      normalizedTitle: string;
      summary: string;
      url: string;
      tags: string[];
      aliases: string[];
      section: string;
      path: string;
      excerpt: string;
    }>;
    tags: Array<{
      label: string;
      url: string;
      count: number;
    }>;
  };
};
---

<section class="rounded-[2rem] border border-base-300 bg-base-100/85 p-5 shadow-sm">
  <div class="space-y-2">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-primary">Search the vault</p>
    <h2 class="display-font text-3xl font-semibold">Jump to notes, tags, and aliases.</h2>
    <p class="max-w-2xl text-sm leading-7 text-base-content/70">
      Start with a word, a tag, or a half-remembered thought and the closest notes will surface here.
    </p>
  </div>

  <div class="relative mt-5">
    <label class="input input-bordered flex items-center gap-3 rounded-2xl bg-base-100/95 shadow-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
      <input
        type="search"
        class="grow"
        placeholder="Search for a note, tag, or half-formed idea..."
        autocomplete="off"
      />
    </label>

    <div class="palette-results absolute inset-x-0 top-[calc(100%+0.85rem)] z-20 rounded-3xl border border-base-300 bg-base-100/95 p-4 shadow-2xl" hidden>
      <div class="grid gap-5 lg:grid-cols-2">
        <section class="space-y-3">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-base-content/50">Notes</p>
          <div class="palette-note-results space-y-3"></div>
        </section>

        <section class="space-y-3">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-base-content/50">Tags</p>
          <div class="palette-tag-results space-y-3"></div>
        </section>
      </div>
    </div>
  </div>

  <script type="application/json" class="search-data" set:html={JSON.stringify(items)} />
  <script is:inline>
    (() => {
      const section = document.currentScript?.parentElement;
      if (!section) return;

      const input = section.querySelector('input[type="search"]');
      const dataNode = section.querySelector('.search-data');
      const results = section.querySelector('.palette-results');
      const noteResults = section.querySelector('.palette-note-results');
      const tagResults = section.querySelector('.palette-tag-results');
      if (!input || !dataNode || !results || !noteResults || !tagResults) return;

      const items = JSON.parse(dataNode.textContent || '{"notes":[],"tags":[]}');

      const renderNotes = (notes) =>
        notes
          .map(
            (item) => `
              <a class="card border border-base-300 bg-base-100 shadow-sm transition hover:border-primary/40 hover:shadow-md" href="${item.url}">
                <div class="card-body gap-2 p-4">
                  <strong class="text-base">${item.title}</strong>
                  <span class="text-xs uppercase tracking-[0.16em] text-base-content/50">${item.section} • ${item.path}</span>
                  <p class="text-sm leading-6 text-base-content/70">${item.summary || item.excerpt}</p>
                </div>
              </a>`,
          )
          .join('');

      const renderTags = (tags) =>
        tags
          .map(
            (item) => `
              <a class="card border border-base-300 bg-base-100 shadow-sm transition hover:border-primary/40 hover:shadow-md" href="${item.url}">
                <div class="card-body gap-1 p-4">
                  <strong class="text-base">#${item.label}</strong>
                  <span class="text-sm text-base-content/70">${item.count} linked note${item.count === 1 ? '' : 's'}</span>
                </div>
              </a>`,
          )
          .join('');

      const closeResults = () => {
        results.hidden = true;
      };

      const render = (query) => {
        const cleaned = query.trim().toLowerCase();

        if (!cleaned) {
          closeResults();
          noteResults.innerHTML = '';
          tagResults.innerHTML = '';
          return;
        }

        const filteredNotes = items.notes
          .filter((item) =>
            [
              item.title,
              item.normalizedTitle,
              item.summary,
              item.excerpt,
              item.section,
              item.path,
              item.tags.join(' '),
              item.aliases.join(' '),
            ]
              .join(' ')
              .toLowerCase()
              .includes(cleaned),
          )
          .slice(0, 6);

        const filteredTags = items.tags
          .filter((item) => item.label.toLowerCase().includes(cleaned))
          .slice(0, 6);

        noteResults.innerHTML = filteredNotes.length
          ? renderNotes(filteredNotes)
          : '<div class="rounded-2xl border border-dashed border-base-300 bg-base-100/70 p-4 text-sm text-base-content/60">No note matches.</div>';

        tagResults.innerHTML = filteredTags.length
          ? renderTags(filteredTags)
          : '<div class="rounded-2xl border border-dashed border-base-300 bg-base-100/70 p-4 text-sm text-base-content/60">No tag matches.</div>';

        results.hidden = false;
      };

      input.addEventListener('input', (event) => render(event.target.value));
      input.addEventListener('focus', () => {
        if (input.value.trim()) {
          render(input.value);
        }
      });
      input.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          input.value = '';
          closeResults();
          input.blur();
        }
      });
      input.addEventListener('blur', () => {
        window.setTimeout(() => {
          if (!section.contains(document.activeElement)) {
            closeResults();
          }
        }, 50);
      });

      document.addEventListener('click', (event) => {
        if (!section.contains(event.target)) {
          closeResults();
        }
      });
    })();
  </script>
</section>
