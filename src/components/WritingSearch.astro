---
const { items } = Astro.props as {
  items: {
    notes: Array<{
      title: string;
      normalizedTitle: string;
      summary: string;
      url: string;
      tags: string[];
      aliases: string[];
      section: string;
      path: string;
      excerpt: string;
    }>;
    tags: Array<{
      label: string;
      url: string;
      count: number;
    }>;
  };
};
---

<section class="search-shell search-palette">
  <div class="search-head">
    <div>
      <p class="eyebrow">Search The Vault</p>
      <h2>Start typing and jump straight into notes, aliases, or tags.</h2>
    </div>
    <p class="search-help">This works like a lightweight command palette for the writing subsite.</p>
  </div>

  <div class="palette-input-shell">
    <label class="search-field palette-field">
      <span class="sr-only">Search writing</span>
      <input type="search" placeholder="Search notes, tags, aliases, folders..." autocomplete="off" />
    </label>

    <div class="palette-results" hidden>
      <div class="palette-group">
        <p class="palette-label">Notes</p>
        <div class="palette-note-results"></div>
      </div>

      <div class="palette-group">
        <p class="palette-label">Tags</p>
        <div class="palette-tag-results"></div>
      </div>
    </div>
  </div>

  <script type="application/json" class="search-data" set:html={JSON.stringify(items)} />
  <script is:inline>
    (() => {
      const section = document.currentScript?.parentElement;
      if (!section) return;

      const input = section.querySelector('input[type="search"]');
      const dataNode = section.querySelector('.search-data');
      const results = section.querySelector('.palette-results');
      const noteResults = section.querySelector('.palette-note-results');
      const tagResults = section.querySelector('.palette-tag-results');
      if (!input || !dataNode || !results || !noteResults || !tagResults) return;

      const items = JSON.parse(dataNode.textContent || '{"notes":[],"tags":[]}');

      const renderNotes = (notes) =>
        notes
          .map(
            (item) => `
              <a class="palette-result" href="${item.url}">
                <strong>${item.title}</strong>
                <span>${item.section} • ${item.path}</span>
                <p>${item.summary || item.excerpt}</p>
              </a>`,
          )
          .join('');

      const renderTags = (tags) =>
        tags
          .map(
            (item) => `
              <a class="palette-result palette-result-tag" href="${item.url}">
                <strong>#${item.label}</strong>
                <span>${item.count} linked note${item.count === 1 ? '' : 's'}</span>
              </a>`,
          )
          .join('');

      const render = (query) => {
        const cleaned = query.trim().toLowerCase();
        const filteredNotes = !cleaned
          ? items.notes.slice(0, 6)
          : items.notes
              .filter((item) =>
                [
                  item.title,
                  item.normalizedTitle,
                  item.summary,
                  item.excerpt,
                  item.section,
                  item.path,
                  item.tags.join(' '),
                  item.aliases.join(' '),
                ]
                  .join(' ')
                  .toLowerCase()
                  .includes(cleaned),
              )
              .slice(0, 8);

        const filteredTags = !cleaned
          ? items.tags.slice(0, 8)
          : items.tags
              .filter((item) => item.label.toLowerCase().includes(cleaned))
              .slice(0, 8);

        noteResults.innerHTML = filteredNotes.length
          ? renderNotes(filteredNotes)
          : '<div class="palette-empty">No note matches.</div>';

        tagResults.innerHTML = filteredTags.length
          ? renderTags(filteredTags)
          : '<div class="palette-empty">No tag matches.</div>';

        results.hidden = false;
      };

      input.addEventListener('focus', () => render(input.value));
      input.addEventListener('input', (event) => render(event.target.value));
      input.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          results.hidden = true;
          input.blur();
        }
      });

      document.addEventListener('click', (event) => {
        if (!section.contains(event.target)) {
          results.hidden = true;
        }
      });
    })();
  </script>
</section>
