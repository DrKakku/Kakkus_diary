---
import BaseLayout from "../layouts/BaseLayout.astro";
import KnowledgeGraph from "../components/KnowledgeGraph.astro";
import NoteCard from "../components/NoteCard.astro";
import { formatDate, getMetadataBadges, humanizeSlug, withBase } from "../lib/content";
import { siteConfig } from "../config/site.config";
import { renderNoteHtml } from "../lib/markdown";
import { getFolderChildren, getSiteData } from "../lib/site-data";

export async function getStaticPaths() {
  const siteData = await getSiteData();

  return [
    ...siteData.notes.map((note) => ({
      params: { slug: note.path },
      props: { type: "file", path: note.path },
    })),
    ...siteData.folders.map((folder) => ({
      params: { slug: folder.path },
      props: { type: "folder", path: folder.path },
    })),
  ];
}

const siteData = await getSiteData();
const { type, path } = Astro.props as {
  type: "file" | "folder";
  path: string;
};

const note = type === "file" ? siteData.notesByPath.get(path) : undefined;
const folderState = type === "folder" ? getFolderChildren(siteData, path) : undefined;
const folder = folderState?.folder;

if (type === "file" && !note) {
  throw new Error(`Missing note for path "${path}"`);
}

if (type === "folder" && !folder) {
  throw new Error(`Missing folder for path "${path}"`);
}

const html = note ? await renderNoteHtml(note, siteData) : "";
const title = note?.title ?? folder?.label ?? humanizeSlug(path.split("/").pop() ?? "Writing");
const description = note?.summary ?? folder?.description ?? "A dynamic slice of the writing vault.";

const breadcrumbs = path.split("/").filter(Boolean).map((segment, index, allSegments) => {
  const itemPath = allSegments.slice(0, index + 1).join("/");
  const itemFolder = siteData.foldersByPath.get(itemPath);

  return {
    label:
      index === allSegments.length - 1 && note
        ? note.title
        : itemFolder?.label ?? humanizeSlug(segment),
    href: withBase("/" + itemPath),
    current: index === allSegments.length - 1,
  };
});

const badges = note ? getMetadataBadges(note.entry.data) : [];
const outboundLinks = note
  ? note.links
      .filter((link) => link.href && link.path)
      .filter((link, index, allLinks) => allLinks.findIndex((candidate) => candidate.href === link.href) === index)
      .slice(0, 8)
  : [];
const hasAsideContent = note
  ? note.backlinks.length > 0 || outboundLinks.length > 0
  : false;
---

<BaseLayout title={title} description={description} theme="writing" enableWritingEnhancers>
  <article class="content-panel article">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href={withBase("/")}>Home</a>
      <span>/</span>
      <a href={withBase("/writing")}>Writing</a>

      {breadcrumbs.map((crumb) => (
        <>
          <span>/</span>
          {crumb.current ? <span>{crumb.label}</span> : <a href={crumb.href}>{crumb.label}</a>}
        </>
      ))}
    </nav>

    {note ? (
      <>
        <header class="article-header">
          <p class="eyebrow">{note.sectionLabel}</p>
          <h1>{note.title}</h1>

          <div class="article-meta">
            <span>{formatDate(note.canonicalDate)}</span>
            <a href={withBase("/writing")}>Writing hub</a>
            <a href={withBase("/" + note.sectionKey)}>{note.sectionLabel}</a>
          </div>

          <div class="chip-row">
            {badges.map((badge) => (
              <span class:list={["chip", badge.tone]}>{badge.label}</span>
            ))}
            {note.tags.map((tag) => (
              <a class="chip chip-muted" href={withBase(`/writing/tags/${tag.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`)}>
                {tag}
              </a>
            ))}
          </div>
        </header>

        <div class:list={["article-aside-grid", !hasAsideContent && "single-column"]}>
          <div class="prose" set:html={html}></div>

          {hasAsideContent && (
            <aside class="aside-panel">
              {note.backlinks.length > 0 && (
                <section>
                  <h3>Backlinks</h3>
                  <ul class="plain-list">
                    {note.backlinks.map((entry) => (
                      <li><a href={entry.url}>{entry.title}</a></li>
                    ))}
                  </ul>
                </section>
              )}

              {outboundLinks.length > 0 && (
                <section>
                  <h3>Linked From Here</h3>
                  <ul class="plain-list">
                    {outboundLinks.map((link) => (
                      <li><a href={link.href}>{link.label}</a></li>
                    ))}
                  </ul>
                </section>
              )}

              {note.related.length > 0 && (
                <section>
                  <h3>Related Notes</h3>
                  <div class="note-list">
                    {note.related.map((entry) => (
                      <NoteCard note={entry} compact />
                    ))}
                  </div>
                </section>
              )}
            </aside>
          )}
        </div>

        <KnowledgeGraph
          title="Local Graph"
          description="Adjust the depth to reveal links surrounding this note, including tag nodes when enabled."
          graph={siteData.graph}
          mode="local"
          focusPath={note.path}
          initialDepth={siteConfig.writing.localGraphDepth}
          showTags={siteConfig.writing.showTagsInGraph}
        />

        {siteConfig.writing.showRelatedNotes && note.related.length > 0 && (
          <section class="copy-stack">
            <div class="section-header">
              <div>
                <p class="eyebrow">Suggested Notes</p>
                <h2>Optional reading paths from this page.</h2>
              </div>
            </div>

            <div class="note-grid">
              {note.related.map((entry) => (
                <NoteCard note={entry} compact />
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <>
        <header class="article-header">
          <p class="eyebrow">Section Page</p>
          <h1>{title}</h1>
          <p class="hero-lead">{description}</p>
          <p class="folder-meta">
            {folderState?.descendantNotes.length ?? 0} notes inside this branch of the writing space.
          </p>
        </header>

        {folderState?.childFolders.length ? (
          <section class="copy-stack">
            <div class="section-header">
              <div>
                <p class="eyebrow">Subfolders</p>
                <h2>Continue deeper into this part of the vault.</h2>
              </div>
            </div>

            <div class="section-grid">
              {folderState.childFolders.map((child) => (
                <a class="folder-card" href={child.url}>
                  <span class="card-eyebrow">{child.descendantNotes.length} notes</span>
                  <strong>{child.label}</strong>
                  <p>{child.description ?? "Nested folder page generated from the imported note tree."}</p>
                </a>
              ))}
            </div>
          </section>
        ) : null}

        <section class="copy-stack">
          <div class="section-header">
            <div>
              <p class="eyebrow">Notes</p>
              <h2>Entries directly inside this folder.</h2>
            </div>
          </div>

          {folderState?.directNotes.length ? (
            <div class="note-grid">
              {folderState.directNotes.map((entry) => (
                <NoteCard note={entry} showSection={false} />
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <p>No direct notes live here yet.</p>
              <p>The branch exists because deeper pages inherit this route as part of the generated writing structure.</p>
            </div>
          )}
        </section>
      </>
    )}
  </article>
</BaseLayout>
