---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getEntryPath,
  getEntryTitle,
  getMetadataBadges,
  withBase,
} from "../lib/content";

const entries = await getCollection("entries");

export async function getStaticPaths() {
  const entries = await getCollection("entries");

  const paths = [];

  const folders = new Set();

  for (const entry of entries) {
    const path = entry.id;
    const parts = path.split("/");

    // Add file route
    paths.push({
      params: { slug: path },
      props: { type: "file", entry, path },
    });

    // Add folder routes
    for (let i = 1; i < parts.length; i++) {
      const folder = parts.slice(0, i).join("/");
      folders.add(folder);
    }
  }

  for (const folder of folders) {
    paths.push({
      params: { slug: folder },
      props: { type: "folder", path: folder },
    });
  }

  return paths;
}

const { type, entry, path } = Astro.props;

const title =
  entry?.data?.title ??
  path.split("/").pop() ??
  "Untitled";

// Folder children
const children =
  type === "folder"
    ? entries.filter((e) => e.id.startsWith(path + "/"))
    : [];

let Content = null;

if (type === "file") {
  const rendered = await render(entry);
  Content = rendered.Content;
}
---

<BaseLayout title={title}>
  <article class="article">
    <nav class="breadcrumbs">
      <a href={withBase("/")}>Home</a>

      {path.split("/").map((p, i, arr) => {
        const href = withBase("/" + arr.slice(0, i + 1).join("/"));
        return (
          <>
            <span>/</span>
            <a href={href}>{p}</a>
          </>
        );
      })}
    </nav>

    <header class="article-header">
      <h1>{title}</h1>
    </header>

    {type === "file" && Content && (
      <div class="prose">
        <Content />
      </div>
    )}

    {type === "folder" && (
      <>
        <h2>Contents</h2>

        <ul>
          {children.map((child) => {
            const childPath = child.id;
            const childTitle =
              child.data.title ??
              childPath.split("/").pop();

            return (
              <li>
                <a href={withBase("/" + childPath)}>
                  {childTitle}
                </a>
              </li>
            );
          })}
        </ul>
      </>
    )}
  </article>
</BaseLayout>