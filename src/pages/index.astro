---
import BaseLayout from "../layouts/BaseLayout.astro";
import NoteCard from "../components/NoteCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { siteConfig } from "../config/site.config";
import { withBase } from "../lib/content";
import { getSiteData } from "../lib/site-data";

const siteData = await getSiteData();
const featuredProjects = siteData.featuredProjects.slice(0, 3);
const featuredWriting = (siteData.featuredWriting.length > 0 ? siteData.featuredWriting : siteData.notes).slice(0, siteConfig.featuredWritingLimit);
const featuredSections = siteData.sections.slice(0, 3);
---

<BaseLayout title={siteConfig.siteName} description={siteConfig.siteDescription} theme="portfolio">
  <section class="hero-panel hero-portfolio">
    <div class="hero-copy">
      <p class="eyebrow">{siteConfig.hero.eyebrow}</p>
      <h1>{siteConfig.hero.headline}</h1>
      <p class="hero-lead">{siteConfig.hero.lead}</p>

      <div class="action-row">
        <a class="button-link" href={withBase(siteConfig.hero.primaryCta.href)}>
          {siteConfig.hero.primaryCta.label}
        </a>
        <a class="button-link button-link-secondary" href={withBase(siteConfig.hero.secondaryCta.href)}>
          {siteConfig.hero.secondaryCta.label}
        </a>
      </div>
    </div>

    <aside class="hero-metrics">
      <div class="metric-card">
        <strong>{siteData.projects.length}</strong>
        <span>active project stories</span>
      </div>
      <div class="metric-card">
        <strong>{siteData.notes.length}</strong>
        <span>published notes</span>
      </div>
      <div class="metric-card">
        <strong>{siteData.sections.length}</strong>
        <span>dynamic writing sections</span>
      </div>
      <div class="metric-card">
        <strong>{siteData.tags.length}</strong>
        <span>tag connections</span>
      </div>
    </aside>
  </section>

  <section class="content-panel">
    <div class="section-header">
      <div>
        <p class="eyebrow">Featured Work</p>
        <h2>Projects that shape the rest of the system.</h2>
      </div>
      <a class="text-link" href={withBase("/projects")}>View all projects</a>
    </div>

    <div class="project-grid">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} featured />
      ))}
    </div>
  </section>

  <section class="content-panel bridge-grid">
    <div>
      <div class="section-header">
        <div>
          <p class="eyebrow">Writing Bridge</p>
          <h2>The blog is a subsite, but it still feeds the portfolio.</h2>
        </div>
        <a class="text-link" href={withBase("/writing")}>Enter writing hub</a>
      </div>

      <div class="note-grid">
        {featuredWriting.map((note) => (
          <NoteCard note={note} showSection />
        ))}
      </div>
    </div>

    <aside class="section-stack">
      {featuredSections.map((section) => (
        <a class="section-card" href={section.url}>
          <span class="card-eyebrow">{section.notes.length} notes</span>
          <strong>{section.label}</strong>
          <p>{section.description}</p>
        </a>
      ))}
    </aside>
  </section>

  <section class="content-panel split-panel">
    <div>
      <p class="eyebrow">About The Builder</p>
      <h2>{siteConfig.profile.name} builds products where content and interface evolve together.</h2>
      <p class="hero-lead">{siteConfig.profile.intro}</p>
    </div>

    <div class="copy-stack">
      {siteConfig.profile.about.map((paragraph) => <p>{paragraph}</p>)}
      <p class="muted-copy">{siteConfig.profile.location} • {siteConfig.profile.availability}</p>
    </div>
  </section>

  <section class="content-panel contact-panel">
    <div class="section-header">
      <div>
        <p class="eyebrow">Connect</p>
        <h2>Portfolio, resume, and public surfaces.</h2>
      </div>
    </div>

    <div class="link-grid">
      {siteConfig.socialLinks.map((link) => (
        <a class="link-tile" href={link.kind === "internal" ? withBase(link.href) : link.href} target={link.kind === "external" ? "_blank" : undefined} rel={link.kind === "external" ? "noreferrer" : undefined}>
          <strong>{link.label}</strong>
          <span>{link.kind === "external" ? "External profile" : "Internal page"}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
