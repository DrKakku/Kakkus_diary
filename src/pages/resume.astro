---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site.config";
---

<BaseLayout title="Resume" description={siteConfig.resume.summary} theme="portfolio">
  <section class="hero-panel hero-portfolio">
    <div class="hero-copy">
      <p class="eyebrow">Resume Surface</p>
      <h1>{siteConfig.profile.name}</h1>
      <p class="hero-lead">{siteConfig.resume.summary}</p>
    </div>
  </section>

  <section class="content-panel split-panel">
    <div>
      <p class="eyebrow">Highlights</p>
      <h2>What I tend to bring into products.</h2>
      <div class="copy-stack">
        {siteConfig.resume.highlights.map((item) => <p>{item}</p>)}
      </div>
    </div>

    <aside class="tag-cloud">
      <p class="eyebrow">Skills</p>
      <h2>Current toolkit.</h2>
      <div class="chip-row">
        {siteConfig.resume.skills.map((skill) => (
          <span class="chip chip-muted">{skill}</span>
        ))}
      </div>
    </aside>
  </section>
</BaseLayout>
