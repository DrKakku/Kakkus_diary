---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateRange } from "../../lib/content";

const projects = await getCollection("projects");

export async function getStaticPaths() {
  const projectEntries = await getCollection("projects");

  return projectEntries.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props as {
  project: (typeof projects)[number];
};

const { Content } = await render(project);
const links = project.data.links ?? {};
---

<BaseLayout title={project.data.title} description={project.data.description ?? project.data.summary} theme="portfolio">
  <section class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(16rem,0.8fr)]">
    <div class="rounded-[2rem] border border-base-300 bg-base-100/80 p-8 shadow-sm sm:p-10">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-primary">{project.data.kind ?? "Project"}</p>
      <h1 class="display-font mt-4 text-4xl font-semibold tracking-tight text-balance sm:text-5xl">{project.data.title}</h1>
      <p class="mt-4 max-w-2xl text-base leading-8 text-base-content/72">
        {project.data.summary ?? project.data.description}
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        {links.live && (
          <a class="btn btn-primary rounded-full px-6" href={links.live} target="_blank" rel="noreferrer">Open live link</a>
        )}
        {links.repo && (
          <a class="btn btn-outline rounded-full px-6" href={links.repo} target="_blank" rel="noreferrer">
            View repository
          </a>
        )}
      </div>
    </div>

    <aside class="rounded-[2rem] border border-base-300 bg-base-100/75 p-6 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-base-content/50">Project details</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {project.data.stack.map((item) => (
          <span class="badge badge-ghost badge-lg">{item}</span>
        ))}
      </div>
      <dl class="mt-5 space-y-4 text-sm">
        {project.data.role && (
          <div>
            <dt class="text-base-content/50">Role</dt>
            <dd class="mt-1 font-medium">{project.data.role}</dd>
          </div>
        )}
        {project.data.status && (
          <div>
            <dt class="text-base-content/50">Status</dt>
            <dd class="mt-1 font-medium">{project.data.status}</dd>
          </div>
        )}
        {project.data.startDate && (
          <div>
            <dt class="text-base-content/50">Timeline</dt>
            <dd class="mt-1 font-medium">{formatDateRange(project.data.startDate, project.data.endDate)}</dd>
          </div>
        )}
      </dl>
    </aside>
  </section>

  <section class="mt-12 rounded-[2rem] border border-base-300 bg-base-100/80 p-6 shadow-sm sm:p-8">
    <div class="article-prose">
      <Content />
    </div>
  </section>
</BaseLayout>
